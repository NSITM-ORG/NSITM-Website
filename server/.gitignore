# ---------------------------------------------------------------------------
# Dependencies (Never commit these; they can be reinstalled via npm install)
# ---------------------------------------------------------------------------
node_modules/
jspm_packages/
package-lock.json

# ---------------------------------------------------------------------------
# Environment Variables & Secrets (CRITICAL: Prevents leaking API keys)
# ---------------------------------------------------------------------------
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.env

# ---------------------------------------------------------------------------
# Logs (Debug information generated by npm and runtime errors)
# ---------------------------------------------------------------------------
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ---------------------------------------------------------------------------
# Build & Output Directories (For TypeScript or bundled applications)
# ---------------------------------------------------------------------------
dist/
build/
out/
.next/
.tsc/

# ---------------------------------------------------------------------------
# IDE & Editor Files
# ---------------------------------------------------------------------------
.vscode/
.idea/
.DS_Store
.env.*.local
*.swp
*.swo
*~
.sublime-project
.sublime-workspace
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# ---------------------------------------------------------------------------
# Temporary Files
# ---------------------------------------------------------------------------
tmp/
temp/
*.tmp
*.bak

# ---------------------------------------------------------------------------
# Upload Directories (Keep structure but ignore uploaded files)
# ---------------------------------------------------------------------------
uploads/temp/*
uploads/optimized/*
!uploads/.gitkeep
!uploads/temp/.gitkeep
!uploads/optimized/.gitkeep

# ---------------------------------------------------------------------------
# OS-specific Files
# ---------------------------------------------------------------------------
Thumbs.db
.DS_Store
.AppleDouble
.LSOverride

# ---------------------------------------------------------------------------
# Runtime Files
# ---------------------------------------------------------------------------
.pids
*.pid
*.seed
*.pid.lock

# ---------------------------------------------------------------------------
# Miscellaneous
# ---------------------------------------------------------------------------
.cache/
.pytest_cache/
.eslintcache
coverage/

